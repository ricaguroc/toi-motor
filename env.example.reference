# ============================================================
# REFERENCIA PARA .env.example
# Copiar este contenido a .env.example en la raiz del proyecto
# ============================================================

# --- PostgreSQL -----------------------------------------------
DATABASE_URL=postgresql://app:secret@localhost:5432/trazabilidad?sslmode=disable

# --- NATS -----------------------------------------------------
NATS_URL=nats://localhost:4222

# --- Embeddings (local via Ollama) ----------------------------
# Convierte texto en vectores para busqueda semantica.
# Corre localmente — los datos nunca salen de tu infra.
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text

# --- LLM (externo, agnostico al proveedor) --------------------
# Interpreta preguntas y genera respuestas en lenguaje
# natural. Externo y configurable.
# NOTA: los datos de las consultas SI salen de tu infra.
LLM_API_KEY=sk-ant-tu-api-key-aqui
LLM_BASE_URL=https://api.anthropic.com
LLM_MODEL=claude-sonnet-4-20250514

# --- API Server -----------------------------------------------
API_PORT=8080
