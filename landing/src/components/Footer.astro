---
import { GITHUB_URL, LINKEDIN_URL, NAV_LINKS } from '../config';
---

<footer class="border-t border-(--color-border) bg-(--color-bg-alt) py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10">
      <!-- Brand -->
      <div class="col-span-2 md:col-span-1">
        <span class="font-mono font-bold text-lg text-(--color-text)">TOI</span>
        <p class="text-sm text-(--color-text-muted) mt-2 leading-relaxed">Motor Universal de Registros.<br/>Open source. Apache 2.0.</p>
      </div>

      <!-- Producto -->
      <div>
        <h4 class="text-xs font-semibold text-(--color-text) uppercase tracking-wider mb-4">Producto</h4>
        <ul class="space-y-2.5">
          {NAV_LINKS.map(link => (
            <li><a href={link.href} class="text-sm text-(--color-text-muted) hover:text-(--color-text) transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Comunidad -->
      <div>
        <h4 class="text-xs font-semibold text-(--color-text) uppercase tracking-wider mb-4">Comunidad</h4>
        <ul class="space-y-2.5">
          <li><a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="text-sm text-(--color-text-muted) hover:text-(--color-text) transition-colors">GitHub</a></li>
          <li><a href={LINKEDIN_URL} target="_blank" rel="noopener noreferrer" class="text-sm text-(--color-text-muted) hover:text-(--color-text) transition-colors">LinkedIn</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div>
        <h4 class="text-xs font-semibold text-(--color-text) uppercase tracking-wider mb-4">Contacto</h4>
        <ul class="space-y-2.5">
          <li><a href="mailto:hola@trazabilidad.io" class="text-sm text-(--color-text-muted) hover:text-(--color-text) transition-colors">hola@trazabilidad.io</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-(--color-border) mt-12 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-(--color-text-muted)">&copy; 2026 TOI. Todos los derechos reservados.</p>
      <p class="text-xs text-(--color-text-muted)">Hecho con Go, PostgreSQL, NATS y RAG.</p>
    </div>
  </div>
</footer>
