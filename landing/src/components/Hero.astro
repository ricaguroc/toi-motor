---
import { GITHUB_URL } from '../config';
---

<section class="pt-28 pb-20 px-6">
  <div class="max-w-3xl mx-auto">
    <!-- Eyebrow -->
    <div class="animate-in flex items-center gap-2 mb-8">
      <span class="inline-flex items-center gap-1.5 text-xs font-medium text-(--color-green) bg-(--color-green-soft) px-2.5 py-1 rounded-full">
        <span class="w-1.5 h-1.5 rounded-full bg-(--color-green)"></span>
        Open Source
      </span>
      <span class="text-xs text-(--color-text-muted)">Apache 2.0</span>
    </div>

    <!-- Headline -->
    <h1 class="animate-in delay-1 text-4xl sm:text-5xl md:text-6xl font-bold tracking-tight leading-[1.1] text-(--color-text)">
      Ingesta cualquier dato.<br/>
      Consultá en<br/>
      <span class="text-(--color-accent)">lenguaje natural.</span>
    </h1>

    <!-- Subtitle -->
    <p class="animate-in delay-2 mt-6 text-lg text-(--color-text-secondary) leading-relaxed max-w-xl">
      TOI es un motor que transforma datos heterogéneos en conocimiento
      buscable usando embeddings, RAG y LLM. API-first, agnóstico al
      proveedor, append-only.
    </p>

    <!-- CTAs -->
    <div class="animate-in delay-3 mt-10 flex flex-wrap items-center gap-4">
      <a href="/empezar" class="px-5 py-2.5 rounded-lg bg-(--color-accent) hover:bg-(--color-accent-hover) text-white text-sm font-medium transition-colors">
        Empezar ahora
      </a>
      <a href="/motor" class="px-5 py-2.5 rounded-lg border border-(--color-border) hover:border-(--color-border-strong) text-(--color-text) text-sm font-medium transition-colors">
        Cómo funciona
      </a>
      <a href={GITHUB_URL} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1.5 text-sm text-(--color-text-muted) hover:text-(--color-text-secondary) transition-colors">
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        Ver en GitHub
      </a>
    </div>
  </div>

  <!-- Terminal -->
  <div class="max-w-3xl mx-auto mt-16 animate-in delay-4">
    <div class="rounded-xl border border-(--color-border) shadow-sm overflow-hidden">
      <!-- Terminal header -->
      <div class="flex items-center gap-2 px-4 py-2.5 bg-(--color-bg-alt) border-b border-(--color-border)">
        <span class="w-2.5 h-2.5 rounded-full bg-(--color-border-strong)"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-(--color-border-strong)"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-(--color-border-strong)"></span>
        <span class="text-xs text-(--color-text-muted) ml-2 font-mono">terminal</span>
      </div>
      <!-- Terminal body -->
      <div class="p-5 bg-white font-mono text-sm leading-7">
        <div>
          <span class="text-(--color-text-muted) select-none">$ </span>
          <span class="text-(--color-text)">toi ingest file</span>
          <span class="text-(--color-accent)"> facturas.csv</span>
          <span class="text-(--color-text-secondary)"> --source erp --type factura</span>
        </div>
        <div class="text-(--color-green)">&#10003; 1,847 registros ingestados en 2.3s</div>

        <div class="mt-4">
          <span class="text-(--color-text-muted) select-none">$ </span>
          <span class="text-(--color-text)">toi query</span>
          <span class="text-(--color-text-secondary)"> "¿qué envíos se retrasaron la semana pasada?"</span>
        </div>
        <div class="text-(--color-text-secondary) mt-1">
          Encontrados <span class="text-(--color-accent) font-semibold">12 registros</span> en <span class="text-(--color-accent) font-semibold">3 fuentes</span>
        </div>
        <div class="mt-2 pl-3 border-l-2 border-(--color-border-strong)">
          <div class="text-(--color-text)">1. Envío <span class="text-(--color-warm) font-semibold">#LP-4821</span> &mdash; retrasado 2 días</div>
          <div class="text-(--color-text-muted) text-xs">Fuente: ERP &middot; Registrado: 2026-03-12</div>
          <div class="text-(--color-text) mt-1">2. Envío <span class="text-(--color-warm) font-semibold">#LP-4835</span> &mdash; retrasado 1 día</div>
          <div class="text-(--color-text-muted) text-xs">Fuente: Scanner &middot; Registrado: 2026-03-13</div>
        </div>
        <div class="mt-3">
          <span class="text-(--color-text-muted) select-none">$ </span>
          <span class="inline-block w-2 h-4 bg-(--color-accent)" style="animation: blink 1s step-end infinite"></span>
        </div>
      </div>
    </div>
  </div>
</section>
