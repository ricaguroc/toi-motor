---
import WaitlistForm from './WaitlistForm.tsx';
---

<section class="py-24 px-6 bg-(--color-bg-alt)">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-3">Mantenete al tanto</h2>
    <p class="text-(--color-text-secondary) mb-8">
      Acceso anticipado al hosting gestionado, nuevos adaptadores y actualizaciones. Sin spam.
    </p>
    <div class="flex justify-center">
      <WaitlistForm client:visible />
    </div>
    <p class="text-xs text-(--color-text-muted) mt-6">
      Open source &middot; Self-host en cualquier momento &middot; Sin vendor lock-in
    </p>
  </div>
</section>
