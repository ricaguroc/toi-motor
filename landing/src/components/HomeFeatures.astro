---
const features = [
  {
    title: 'Registros universales',
    description: 'Un modelo flexible para cualquier dato: escaneos, documentos, notas, movimientos. Schema abierto con metadata, tags y referencias.',
  },
  {
    title: 'Adaptadores conectables',
    description: 'CSV, JSON, APIs, ERPs, scanners. Importá archivos desde el CLI o conectá fuentes via API. Escribí tu propio adapter en Go.',
  },
  {
    title: 'LLM agnóstico',
    description: 'Cambiá de proveedor sin tocar una línea de código. Anthropic, OpenAI, Ollama, o cualquier API compatible.',
  },
  {
    title: 'Append-only',
    description: 'Los registros son inmutables. No hay Update ni Delete. Auditoría completa por diseño. Checksum SHA-256 por registro.',
  },
  {
    title: 'Pipeline async',
    description: 'La ingesta nunca bloquea. Los registros viajan por NATS, se embeben de forma asíncrona, y son buscables en segundos.',
  },
  {
    title: 'Arquitectura hexagonal',
    description: 'Ports y adapters. Cambiá la base de datos, la cola de mensajes, o el proveedor de LLM. El dominio queda puro.',
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="max-w-3xl mx-auto text-center mb-16">
      <p class="text-xs font-semibold text-(--color-accent) uppercase tracking-wider mb-4">Características</p>
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight">Construido para datos del mundo real</h2>
      <p class="text-(--color-text-secondary) mt-4">No es otra base de datos. Es un motor que hace buscables registros heterogéneos en lenguaje natural.</p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map(f => (
        <div class="group">
          <h3 class="text-base font-semibold text-(--color-text) mb-2">{f.title}</h3>
          <p class="text-sm text-(--color-text-secondary) leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
